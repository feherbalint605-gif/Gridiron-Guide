# PostgreSQL connection string (Supabase example below).
# For production/serverless (Vercel), use Supabase's "Connection Pooling" (pgbouncer) port 6543.
# For running migrations (drizzle-kit push), use the direct connection port 5432 instead.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-region.pooler.supabase.com:6543/postgres

# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth credentials (Google Cloud Console > APIs & Services > Credentials).
# Add an "Authorized redirect URI" for every domain you run this app on, e.g.:
#   https://your-app.vercel.app/api/callback
#   http://localhost:5000/api/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Standard Node/Express settings
NODE_ENV=production
PORT=5000
